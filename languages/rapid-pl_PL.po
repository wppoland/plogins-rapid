#. Plugin Name of the plugin
#: rapid.php
msgid "Rapid - Quick Order Form for WooCommerce"
msgstr "Rapid - Szybki formularz zamówień dla WooCommerce"

#. Plugin URI of the plugin
#: rapid.php
msgid "https://plogins.com/rapid/"
msgstr "https://plogins.com/rapid/"

#. Description of the plugin
#: rapid.php
msgid "A fast bulk order form so B2B and wholesale buyers can add many products at once."
msgstr "Szybki formularz zamówień zbiorczych, dzięki któremu kupujący B2B i hurtowi mogą dodać wiele produktów naraz."

#. Author of the plugin
#: rapid.php
msgid "WPPoland"
msgstr "WPPoland"

#. Author URI of the plugin
#: rapid.php
msgid "https://plogins.com/"
msgstr "https://plogins.com/"

#: rapid.php:47
msgid "Rapid - Quick Order Form for WooCommerce requires WooCommerce to be active."
msgstr "Rapid - Szybki formularz zamówień dla WooCommerce wymaga aktywnego WooCommerce."

#: src/Admin/Settings.php:65
msgid "Rapid — Quick Order Form"
msgstr "Rapid — Szybki formularz zamówień"

#: src/Admin/Settings.php:66
msgid "Rapid"
msgstr "Rapid"

#: src/Admin/Settings.php:107
msgid "A fast bulk order form for your shop"
msgstr "Szybki formularz zamówień zbiorczych dla Twojego sklepu"

#. translators: %s: shortcode wrapped in <code>.
#: src/Admin/Settings.php:112
#, php-format
msgid "Drop %s into any page to let customers search products by name or SKU, set quantities and add many to the cart in one click — perfect for B2B, wholesale and reorders."
msgstr "Umieść %s na dowolnej stronie, aby klienci mogli wyszukiwać produkty po nazwie lub SKU, ustawiać ilości i dodawać wiele pozycji do koszyka jednym kliknięciem — idealne dla B2B, sprzedaży hurtowej i ponownych zamówień."

#: src/Admin/Settings.php:123
msgid "General"
msgstr "Ogólne"

#: src/Admin/Settings.php:128
msgid "Enable quick order"
msgstr "Włącz szybkie zamawianie"

#: src/Admin/Settings.php:139
msgid "Show the quick order form on the storefront."
msgstr "Wyświetlaj szybki formularz zamówień w sklepie."

#: src/Admin/Settings.php:148
msgid "Product scope"
msgstr "Zakres produktów"

#: src/Admin/Settings.php:153
msgid "Which products?"
msgstr "Które produkty?"

#: src/Admin/Settings.php:162
msgid "All products"
msgstr "Wszystkie produkty"

#: src/Admin/Settings.php:165
msgid "Selected categories only"
msgstr "Tylko wybrane kategorie"

#: src/Admin/Settings.php:175
msgid "Categories"
msgstr "Kategorie"


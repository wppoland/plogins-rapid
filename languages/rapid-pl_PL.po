msgid "No product categories found yet."
msgstr "Nie znaleziono jeszcze żadnych kategorii produktów."

#: src/Admin/Settings.php:182
msgid "Product categories"
msgstr "Kategorie produktów"

#: src/Admin/Settings.php:203
msgid "Columns"
msgstr "Kolumny"

#: src/Admin/Settings.php:204
msgid "Choose which columns appear in the order table. Product name and quantity are always shown."
msgstr "Wybierz, które kolumny mają się pojawiać w tabeli zamówień. Nazwa produktu i ilość są wyświetlane zawsze."

